# =============================================================================
# personal-ming-stack — Environment Variable Template
# =============================================================================
# Copy this file to .env and fill in your values before running docker compose.
# NEVER commit .env to git. Only .env-example should be committed.
# =============================================================================


# -----------------------------------------------------------------------------
# MOSQUITTO (MQTT Broker)
# -----------------------------------------------------------------------------
# Port for standard MQTT communication (default: 1883)
MOSQUITTO_PORT=1883
# Port for MQTT over WebSockets, used by Node-RED and browser clients (default: 9001)
MOSQUITTO_WS_PORT=9001
# MQTT client username and password — must match your mosquitto passwd file
MQTT_USERNAME=mqtt_user
MQTT_PASSWORD=changeme_mqtt


# -----------------------------------------------------------------------------
# INFLUXDB
# -----------------------------------------------------------------------------
INFLUXDB_PORT=8086
# Admin credentials for the InfluxDB UI and API
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=changeme_influx
# Organization and bucket created on first init — used by Node-RED and Grafana
INFLUXDB_ORG=my_lab
INFLUXDB_BUCKET=lab_data
# Initial admin token — PIN THIS VALUE so rebuilds don't break Grafana's datasource connection.
# Generate once with: openssl rand -hex 32
INFLUXDB_ADMIN_TOKEN=changeme_generate_a_real_token_here


# -----------------------------------------------------------------------------
# NODE-RED
# -----------------------------------------------------------------------------
NODERED_PORT=1880
# Set a username and bcrypt-hashed password for the Node-RED editor.
# Generate hash with: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 8))"
NODERED_ADMIN_USER=admin
NODERED_ADMIN_PASSWORD_HASH=changeme_bcrypt_hash
# Credential encryption key — used to encrypt secrets stored in flows.json
# Generate with: openssl rand -hex 32
NODERED_CREDENTIAL_SECRET=changeme_generate_a_real_secret_here


# -----------------------------------------------------------------------------
# GRAFANA
# -----------------------------------------------------------------------------
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana
# Prevent new users from registering via the UI
GF_USERS_ALLOW_SIGN_UP=false
# Disable anonymous access — important for LAN security
GF_AUTH_ANONYMOUS_ENABLED=false
# Organization name shown in the Grafana UI
GF_SECURITY_ADMIN_EMAIL=admin@lab.local


# -----------------------------------------------------------------------------
# POSTGRESQL (Shared — used by OMERO and optionally other services)
# -----------------------------------------------------------------------------
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres
# OMERO's dedicated database within the shared Postgres instance
OMERO_DB_NAME=omero
OMERO_DB_USER=omero_user
OMERO_DB_PASSWORD=changeme_omero_db


# -----------------------------------------------------------------------------
# OMERO SERVER
# -----------------------------------------------------------------------------
# OMERO.server OMERO ports (Ice communication)
OMERO_SERVER_PORT_4063=4063
OMERO_SERVER_PORT_4064=4064
# Root (admin) password for the OMERO application itself (not the DB)
# This is the password you use to log into OMERO.web or OMERO Insight as "root"
OMERO_ROOT_PASSWORD=changeme_omero_root


# -----------------------------------------------------------------------------
# OMERO WEB
# -----------------------------------------------------------------------------
OMERO_WEB_PORT=4080
# Hostname or IP that OMERO.web uses to reach OMERO.server
# On a single host this is the container service name
OMERO_HOST=omero-server


# -----------------------------------------------------------------------------
# NETWORK / HOST
# -----------------------------------------------------------------------------
# The LAN IP or hostname of the machine running this stack.
# Used for inter-container references and any config that needs the host address.
HOST_IP=192.168.1.100
HOST_HOSTNAME=labserver.local